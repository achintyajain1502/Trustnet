datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Date {
  id    String @id @default(cuid())
  event String
  date  String
}

model Speaker {
  id          String @id @default(cuid())
  name        String
  affiliation String
  image       String
}

model Committee {
  id          String @id @default(cuid())
  name        String
  designation String
  image       String
}

model Publisher {
  id   String @id @default(cuid())
  name String
  logo String
}

model Partner {
  id   String @id @default(cuid())
  name String
  logo String
}

model Navigation {
  id    String @id @default(cuid())
  title String
  link  String
  order Int
}

model Tab {
  id       String @id @default(cuid())
  tabName  String
  headline String
  content  String
  image    String
  slug     String
}